# Source this file from the voice-assistant-backend directory:
#   source .env.local

export SPRING_PROFILES_ACTIVE=local

# The setup script creates this database role and database. These credentials are
# intentionally local-only; do not reuse them outside your development machine.
export LOCAL_POSTGRES_URL=jdbc:postgresql://localhost:5432/voiceassistant
export LOCAL_POSTGRES_USER=voiceassistant
export LOCAL_POSTGRES_PASSWORD=voiceassistant

export OLLAMA_BASE_URL=http://localhost:11434
export OLLAMA_CHAT_MODEL=llama3.2:1b
# A vision-capable Ollama model used only by the form scanner.
export FORM_SCAN_VISION_MODEL=moondream
export WHISPER_BASE_URL=http://localhost:9000
export APP_FRONTEND_URL=http://localhost:5173
export GOOGLE_TOKENS_DIRECTORY="$PWD/.local/google-tokens"

# These values are required before Google sign-in can be used. Configure an OAuth
# client with http://localhost:8081/login/oauth2/code/google as an authorised
# redirect URI, then replace the placeholder values below.
export GOOGLE_CALENDAR_CLIENT_ID=replace-with-local-google-client-id
export GOOGLE_CALENDAR_CLIENT_SECRET=replace-with-local-google-client-secret

# Prefer an installed Java 21 runtime. This fallback supports Homebrew's keg-only
# openjdk@21 when it has not been symlinked into /Library/Java/JavaVirtualMachines.
if [[ -z "${JAVA_HOME:-}" ]] && /usr/libexec/java_home -v 21 >/dev/null 2>&1; then
  export JAVA_HOME="$(/usr/libexec/java_home -v 21)"
elif [[ -z "${JAVA_HOME:-}" ]] && command -v brew >/dev/null 2>&1; then
  export JAVA_HOME="$(brew --prefix openjdk@21)/libexec/openjdk.jdk/Contents/Home"
fi
